# EditorConfig — konsisten untuk semua editor & AI
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.go]
indent_style = tab
indent_size = 8

[*.{js,ts,tsx,jsx,json,css,html,md,yaml,yml}]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
indent_size = 4

[*.{sh,bash,zsh}]
indent_style = space
indent_size = 2
