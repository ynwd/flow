import { describe, it, expect, vi, beforeEach } from "vitest";
import { list__FEATURE_TITLE__, create__FEATURE_TITLE__, get__FEATURE_TITLE__, update__FEATURE_TITLE__, delete__FEATURE_TITLE__, __clearCache } from "./api";

const mockPosts = [
  { id: "1", title: "First", content: "Hello", author: "Alice", created_at: "2026-01-01T00:00:00Z", updated_at: "2026-01-01T00:00:00Z" },
  { id: "2", title: "Second", content: "World", author: "Bob", created_at: "2026-01-02T00:00:00Z", updated_at: "2026-01-02T00:00:00Z" },
];

describe("list__FEATURE_TITLE__", () => {
  beforeEach(() => {
    vi.restoreAllMocks();
    __clearCache();
  });

  it("returns posts on success", async () => {
    vi.spyOn(globalThis, "fetch").mockResolvedValue(new Response(JSON.stringify(mockPosts), { status: 200 }));
    const result = await list__FEATURE_TITLE__();
    expect(result).toEqual(mockPosts);
    expect(fetch).toHaveBeenCalledWith("/api/__FEATURE__", undefined);
  });

  it("throws on non-ok response", async () => {
    vi.spyOn(globalThis, "fetch").mockResolvedValue(new Response(null, { status: 500 }));
    await expect(list__FEATURE_TITLE__()).rejects.toThrow("Failed: 500");
  });
});

describe("create__FEATURE_TITLE__", () => {
  beforeEach(() => vi.restoreAllMocks());

  it("creates on success", async () => {
    const newPost = { id: "3", title: "New", content: "Body", author: "Me", created_at: "", updated_at: "" };
    vi.spyOn(globalThis, "fetch").mockResolvedValue(new Response(JSON.stringify(newPost), { status: 201 }));
    const result = await create__FEATURE_TITLE__({ title: "New", content: "Body", author: "Me" });
    expect(result).toEqual(newPost);
    expect(fetch).toHaveBeenCalledWith("/api/__FEATURE__", expect.objectContaining({ method: "POST" }));
  });

  it("throws on error", async () => {
    vi.spyOn(globalThis, "fetch").mockResolvedValue(new Response(null, { status: 500 }));
    await expect(create__FEATURE_TITLE__({ title: "X", content: "Y", author: "Z" })).rejects.toThrow("Failed: 500");
  });
});

describe("get__FEATURE_TITLE__", () => {
  beforeEach(() => vi.restoreAllMocks());

  it("returns post on success", async () => {
    vi.spyOn(globalThis, "fetch").mockResolvedValue(new Response(JSON.stringify(mockPosts[0]), { status: 200 }));
    const result = await get__FEATURE_TITLE__("1");
    expect(result).toEqual(mockPosts[0]);
    expect(fetch).toHaveBeenCalledWith("/api/__FEATURE__/1", undefined);
  });

  it("throws on 404", async () => {
    vi.spyOn(globalThis, "fetch").mockResolvedValue(new Response(null, { status: 404 }));
    await expect(get__FEATURE_TITLE__("999")).rejects.toThrow("Failed: 404");
  });
});

describe("update__FEATURE_TITLE__", () => {
  beforeEach(() => vi.restoreAllMocks());

  it("updates on success", async () => {
    const updated = { ...mockPosts[0], title: "Updated" };
    vi.spyOn(globalThis, "fetch").mockResolvedValue(new Response(JSON.stringify(updated), { status: 200 }));
    const result = await update__FEATURE_TITLE__("1", { title: "Updated", content: "New" });
    expect(result.title).toBe("Updated");
    expect(fetch).toHaveBeenCalledWith("/api/__FEATURE__/1", expect.objectContaining({ method: "PUT" }));
  });

  it("throws on error", async () => {
    vi.spyOn(globalThis, "fetch").mockResolvedValue(new Response(null, { status: 404 }));
    await expect(update__FEATURE_TITLE__("999", { title: "X", content: "Y" })).rejects.toThrow("Failed: 404");
  });
});

describe("delete__FEATURE_TITLE__", () => {
  beforeEach(() => vi.restoreAllMocks());

  it("deletes on success", async () => {
    vi.spyOn(globalThis, "fetch").mockResolvedValue(new Response(null, { status: 204 }));
    await delete__FEATURE_TITLE__("1");
    expect(fetch).toHaveBeenCalledWith("/api/__FEATURE__/1", expect.objectContaining({ method: "DELETE" }));
  });

  it("throws on error", async () => {
    vi.spyOn(globalThis, "fetch").mockResolvedValue(new Response(null, { status: 500 }));
    await expect(delete__FEATURE_TITLE__("999")).rejects.toThrow("Failed: 500");
  });
});
