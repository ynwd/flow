import * as esbuild from 'esbuild';

const isWatch = process.argv.includes('--watch');
const isAnalyze = process.argv.includes('--analyze');

/** @type {esbuild.BuildOptions} */
const config = {
    entryPoints: ['__FEATURE_TITLE__.tsx'],
    outdir: 'static/dist',
    bundle: true,
    splitting: true,
    format: 'esm',
    chunkNames: 'chunks/[name]-[hash]',
    entryNames: '__FEATURE__',
    minify: !isWatch,
    sourcemap: isWatch ? 'inline' : false,
    target: 'es2020',
    loader: {
        '.tsx': 'tsx',
        '.ts': 'ts',
    },
    // React & ReactDOM are bundled into each module for standalone use.
    // No external vendor needed — keeps deployment simple.
    define: {
        'process.env.NODE_ENV': isWatch ? '"development"' : '"production"',
    },
    // Tree shaking: drop dead code via pure annotations
    treeShaking: true,
    // Metafile for bundle analysis
    metafile: !isWatch,
};

async function main() {
    if (isWatch) {
        const ctx = await esbuild.context(config);
        await ctx.watch();
        console.log('[esbuild] watching for changes...');
        return;
    }

    const result = await esbuild.build(config);
    const out = result.outputFiles ? Object.keys(result.outputFiles).length : '?';
    console.log(`[esbuild] build complete -> static/dist/ (${out} files)`);

    if (result.metafile) {
        const analysis = await esbuild.analyzeMetafile(result.metafile, { verbose: false });
        console.log('\n── Bundle Analysis ──');
        console.log(analysis);
    }

    if (isAnalyze) {
        const analysis = await esbuild.analyzeMetafile(result.metafile, { verbose: true });
        console.log('\n── Detailed Analysis ──');
        console.log(analysis);
    }
}

main().catch((e) => {
    console.error(e);
    process.exit(1);
});
