{{range .Items}}
<article class="bg-bg-card border border-border-subtle rounded-xl p-4 transition-all" style="animation-delay: {{.Delay}}ms">
  <div class="flex justify-between items-start gap-3">
    <div class="flex-1 min-w-0">
      <a href="/__FEATURE__/{{.ID}}" class="block text-[0.9375rem] font-semibold text-text-primary no-underline mb-1 leading-snug hover:text-accent transition-colors">
        {{.Title}}
      </a>
      <p class="text-sm text-text-secondary leading-relaxed m-0 line-clamp-2">{{.Content}}</p>
    </div>
  </div>
  <div class="flex gap-3 mt-2 pt-2 border-t border-border-subtle text-[0.6875rem] text-text-tertiary">
    <span>By <strong class="font-medium text-text-secondary">{{.Author}}</strong></span>
    <span>{{.Date}}</span>
  </div>
</article>
{{end}}
