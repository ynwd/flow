@import "tailwindcss";
@source "../../../../.github/skills/init-core-project/templates/core/templates/";
@source "../../../../.github/skills/init-core-project/templates/core/static/";
@source "../../../../modules/";
@source "../../templates/";

/* ── Dark / Light theme (class-based) ──────────────────────────── */
:root {
  color-scheme: dark;
  --bg-primary: #0a0a0b;
  --bg-secondary: #0e0e0f;
  --bg-card: #121213;
  --bg-hover: #1a1a1c;
  --border: rgba(255, 255, 255, 0.06);
  --text-primary: #e4e4e7;
  --text-secondary: #a1a1aa;
  --text-tertiary: #52525b;
  --text-muted: #3f3f46;
  --accent: #3b82f6;
  --accent-hover: #60a5fa;
  --accent-subtle: rgba(59, 130, 246, 0.08);
  --red: #ef4444;
  --red-subtle: rgba(239, 68, 68, 0.08);
}

.light {
  color-scheme: light;
  --bg-primary: #fafafa;
  --bg-secondary: #f5f5f5;
  --bg-card: #ffffff;
  --bg-hover: #e5e5e5;
  --border: rgba(0, 0, 0, 0.08);
  --text-primary: #09090b;
  --text-secondary: #52525b;
  --text-tertiary: #a1a1aa;
  --text-muted: #d4d4d8;
  --accent: #3b82f6;
  --accent-hover: #2563eb;
  --accent-subtle: rgba(59, 130, 246, 0.08);
  --red: #ef4444;
  --red-subtle: rgba(239, 68, 68, 0.08);
}

/* ── Tailwind v4 custom theme ─────────────────────────────────── */
@theme {
  --color-bg-primary: var(--bg-primary);
  --color-bg-secondary: var(--bg-secondary);
  --color-bg-card: var(--bg-card);
  --color-bg-hover: var(--bg-hover);
  --color-border-subtle: var(--border);
  --color-border: var(--border);
  --color-text-primary: var(--text-primary);
  --color-text-secondary: var(--text-secondary);
  --color-text-tertiary: var(--text-tertiary);
  --color-text-muted: var(--text-muted);
  --color-accent: var(--accent);
  --color-accent-hover: var(--accent-hover);
  --color-accent-subtle: var(--accent-subtle);
  --color-red: var(--red);
  --color-red-subtle: var(--red-subtle);
}

/* ── Global ────────────────────────────────────────────────────── */
html {
  scroll-behavior: smooth;
}

body {
  background: var(--bg-primary);
  color: var(--text-primary);
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}
