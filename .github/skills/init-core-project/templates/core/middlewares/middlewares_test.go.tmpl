func TestPrivateValidToken(t *testing.T) {
	req := httptest.NewRequest(http.MethodGet, "/private", nil)
	req.Header.Set("Authorization", "Bearer mysecrettoken")
	rec := httptest.NewRecorder()

	var userID string
	handler := Private(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		if v, ok := r.Context().Value(UserIDKey).(string); ok {
			userID = v
		}
		w.WriteHeader(http.StatusOK)
	}))

	handler.ServeHTTP(rec, req)

	if rec.Code != http.StatusOK {
		t.Errorf("expected 200, got %d", rec.Code)
	}
	if userID != "mysecrettoken" {
		t.Errorf("expected 'mysecrettoken', got '%s'", userID)
	}
}

