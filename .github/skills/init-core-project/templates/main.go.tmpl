package main

import (
	"context"
	"fmt"
	"net/http"
	"os"
	"os/signal"
	"syscall"
	"time"

	"github.com/ynwd/flow/core/middlewares"
	"github.com/ynwd/flow/core/router"
	_ "github.com/ynwd/flow/modules"
)

func main() {
	// ── Set up multiplexer ────────────────────────────────────────
	mux := http.NewServeMux()

	// Mount static file server and module routes
	router.BuildRouter(mux)

	// ── Determine port ────────────────────────────────────────────
	port := os.Getenv("PORT")
	if port == "" {
		port = "3000"
	}

	// ── HTTP server with middleware ───────────────────────────────
	srv := &http.Server{
		Addr:           ":" + port,
		Handler:        middlewares.Logging(mux),
		ReadTimeout:    5 * time.Second,
		WriteTimeout:   10 * time.Second,
		IdleTimeout:    30 * time.Second,
		MaxHeaderBytes: 1 << 20,
	}

	fmt.Printf("🚀 Server is running at http://localhost:%s\n", port)

	// ── Graceful shutdown ────────────────────────────────────────
	idleConnsClosed := make(chan struct{})
	go func() {
		sigCh := make(chan os.Signal, 1)
		signal.Notify(sigCh, syscall.SIGINT, syscall.SIGTERM)
		sig := <-sigCh

		fmt.Printf("\n🛑 Received %v. Shutting down gracefully...\n", sig)

		ctx, cancel := context.WithTimeout(context.Background(), 10*time.Second)
		defer cancel()

		if err := srv.Shutdown(ctx); err != nil {
			fmt.Printf("⚠️ Server forced to shutdown: %v\n", err)
		}
		close(idleConnsClosed)
	}()

	if err := srv.ListenAndServe(); err != http.ErrServerClosed {
		panic("Failed to start web server: " + err.Error())
	}

	<-idleConnsClosed
}
