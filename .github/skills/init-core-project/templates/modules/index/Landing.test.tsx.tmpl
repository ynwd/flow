import { describe, it, expect } from "vitest";
import { render, screen, fireEvent } from "@testing-library/react";
import { Landing } from "./Landing";

describe("Landing", () => {
  it("renders header with logo and version badge", () => {
    render(<Landing />);
    expect(screen.getByText("F")).toBeInTheDocument();
    expect(screen.getByText("flow")).toBeInTheDocument();
    expect(screen.getAllByText("v0.1.0").length).toBeGreaterThanOrEqual(1);
  });

  it("renders theme toggle button", () => {
    render(<Landing />);
    const toggleBtn = screen.getByTitle("Toggle theme");
    expect(toggleBtn).toBeInTheDocument();
  });

  it("renders hero section", () => {
    render(<Landing />);
    expect(screen.getByText("Welcome to")).toBeInTheDocument();
    expect(screen.getByText("Flow")).toBeInTheDocument();
    expect(screen.getByText(/Your app is running/)).toBeInTheDocument();
  });

  it("renders status indicator", () => {
    render(<Landing />);
    expect(screen.getByText("Online")).toBeInTheDocument();
  });

  it("renders all 3 steps", () => {
    render(<Landing />);
    expect(screen.getByText("Scaffold a module")).toBeInTheDocument();
    expect(screen.getByText("make scaffold")).toBeInTheDocument();
    expect(screen.getByText("Auto-registered")).toBeInTheDocument();
    expect(screen.getByText("init() auto-registers the module")).toBeInTheDocument();
    expect(screen.getByText("Run the server")).toBeInTheDocument();
    expect(screen.getByText("make run")).toBeInTheDocument();
  });

  it("renders CTA buttons", () => {
    render(<Landing />);
    expect(screen.getByText("Repository")).toBeInTheDocument();
    expect(screen.getByText("Docs")).toBeInTheDocument();
  });

  it("renders footer links", () => {
    render(<Landing />);
    expect(screen.getByText("Go")).toBeInTheDocument();
    expect(screen.getByText("React")).toBeInTheDocument();
    expect(screen.getByText("Tailwind")).toBeInTheDocument();
  });

  it("toggles theme on button click", () => {
    render(<Landing />);
    const toggleBtn = screen.getByTitle("Toggle theme");

    // Record initial state
    const hadLight = document.documentElement.classList.contains("light");

    // Click → should toggle
    fireEvent.click(toggleBtn);
    expect(document.documentElement.classList.contains("light")).toBe(!hadLight);

    // Click again → back to original
    fireEvent.click(toggleBtn);
    expect(document.documentElement.classList.contains("light")).toBe(hadLight);
  });

  it("renders current year in footer", () => {
    render(<Landing />);
    const year = new Date().getFullYear().toString();
    expect(screen.getByText(new RegExp(year))).toBeInTheDocument();
  });
});
