{
  "private": true,
  "type": "module",
  "workspaces": ["modules/*"],
  "scripts": {
    "dev": "go run .",
    "build": "echo 'Use: npm run build -w modules/<feature>'",
    "watch": "echo 'Use: npm run watch -w modules/<feature>'",
    "build:css": "postcss core/static/css/app.css -o core/static/css/app.min.css",
    "watch:css": "postcss core/static/css/app.css -o core/static/css/app.min.css --watch",
    "test:all": "go test ./... && npx vitest run",
    "test:go": "go test ./...",
    "test:fe": "npx vitest run",
    "fmt": "gofmt -w .",
    "lint": "golangci-lint run ./... && ./node_modules/.bin/eslint 'modules/**/*.{ts,tsx}'"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "esbuild": "^0.25.0",
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.3",
    "postcss-cli": "^11.0.1",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.5.0",
    "vitest": "^4.1.10"
  }
}
