import { describe, it, expect, vi } from 'vitest';
import { render, screen, fireEvent } from '@testing-library/react';
import { Card } from './Card';

describe('Card', () => {
  // ============================================
  // Container
  // ============================================

  describe('Card.Container', () => {
    it('renders children', () => {
      render(
        <Card>
          <div data-testid="child">Child content</div>
        </Card>
      );
      expect(screen.getByTestId('child')).toBeInTheDocument();
    });

    it('applies default variant classes', () => {
      const { container } = render(<Card>Content</Card>);
      const card = container.firstChild as HTMLElement;
      expect(card.className).toContain('bg-white');
      expect(card.className).toContain('rounded-lg');
    });

    it('applies modal variant classes', () => {
      const { container } = render(<Card variant="modal">Content</Card>);
      const card = container.firstChild as HTMLElement;
      expect(card.className).toContain('rounded-xl');
      expect(card.className).toContain('shadow-xl');
    });

    it('accepts custom className', () => {
      const { container } = render(<Card className="custom-class">Content</Card>);
      const card = container.firstChild as HTMLElement;
      expect(card.className).toContain('custom-class');
    });
  });

  // ============================================
  // Header
  // ============================================

  describe('Card.Header', () => {
    it('renders title', () => {
      render(
        <Card>
          <Card.Header title="Test Title" />
        </Card>
      );
      expect(screen.getByText('Test Title')).toBeInTheDocument();
    });

    it('shows close button when onClose provided', () => {
      const onClose = vi.fn();
      render(
        <Card>
          <Card.Header title="Title" onClose={onClose} />
        </Card>
      );
      const closeButton = screen.getByLabelText('Close');
      fireEvent.click(closeButton);
      expect(onClose).toHaveBeenCalledTimes(1);
    });

    it('hides close button when onClose not provided', () => {
      render(
        <Card>
          <Card.Header title="Title" />
        </Card>
      );
      expect(screen.queryByLabelText('Close')).not.toBeInTheDocument();
    });

    it('renders progress bar when total > 1', () => {
      render(
        <Card>
          <Card.Header title="Title" progress={{ current: 1, total: 3 }} />
        </Card>
      );
      const progressbar = screen.getByRole('progressbar');
      expect(progressbar).toBeInTheDocument();
      expect(progressbar).toHaveAttribute('aria-valuenow', '1');
      expect(progressbar).toHaveAttribute('aria-valuemax', '3');
    });

    it('hides progress bar when total = 1', () => {
      render(
        <Card>
          <Card.Header title="Title" progress={{ current: 1, total: 1 }} />
        </Card>
      );
      expect(screen.queryByRole('progressbar')).not.toBeInTheDocument();
    });

    it('hides progress bar when progress not provided', () => {
      render(
        <Card>
          <Card.Header title="Title" />
        </Card>
      );
      expect(screen.queryByRole('progressbar')).not.toBeInTheDocument();
    });
  });

  // ============================================
  // Content
  // ============================================

  describe('Card.Content', () => {
    it('renders children', () => {
      render(
        <Card>
          <Card.Content>
            <p data-testid="content">Content here</p>
          </Card.Content>
        </Card>
      );
      expect(screen.getByTestId('content')).toBeInTheDocument();
    });

    it('applies padding by default', () => {
      const { container } = render(
        <Card>
          <Card.Content>Content</Card.Content>
        </Card>
      );
      const content = container.querySelector('[class*="p-6"]');
      expect(content).toBeInTheDocument();
    });

    it('applies no padding when padding="none"', () => {
      const { container } = render(
        <Card>
          <Card.Content padding="none">Content</Card.Content>
        </Card>
      );
      const contentDiv = container.querySelector('.p-6, .p-3, .p-8');
      expect(contentDiv).not.toBeInTheDocument();
    });
  });

  // ============================================
  // Footer
  // ============================================

  describe('Card.Footer', () => {
    it('renders step counter centered', () => {
      const { container } = render(
        <Card>
          <Card.Footer
            prevButton={{ label: 'Prev', onClick: () => {} }}
            nextButton={{ label: 'Next', onClick: () => {} }}
            stepIndicator={{ current: 2, total: 3 }}
          />
        </Card>
      );
      expect(screen.getByText('2/3')).toBeInTheDocument();
    });

    it('calls onClick when Prev clicked', () => {
      const onPrev = vi.fn();
      render(
        <Card>
          <Card.Footer
            prevButton={{ label: 'Prev', onClick: onPrev }}
            stepIndicator={{ current: 1, total: 3 }}
          />
        </Card>
      );
      fireEvent.click(screen.getByText('Prev'));
      expect(onPrev).toHaveBeenCalledTimes(1);
    });

    it('calls onClick when Next clicked', () => {
      const onNext = vi.fn();
      render(
        <Card>
          <Card.Footer
            nextButton={{ label: 'Next', onClick: onNext }}
            stepIndicator={{ current: 1, total: 3 }}
          />
        </Card>
      );
      fireEvent.click(screen.getByText('Next'));
      expect(onNext).toHaveBeenCalledTimes(1);
    });

    it('hides Prev when not provided', () => {
      render(
        <Card>
          <Card.Footer
            nextButton={{ label: 'Next', onClick: () => {} }}
            stepIndicator={{ current: 1, total: 3 }}
          />
        </Card>
      );
      expect(screen.queryByText('Prev')).not.toBeInTheDocument();
    });

    it('hides step indicator when not provided', () => {
      render(
        <Card>
          <Card.Footer
            prevButton={{ label: 'Prev', onClick: () => {} }}
            nextButton={{ label: 'Next', onClick: () => {} }}
          />
        </Card>
      );
      expect(screen.queryByText(/\d+\/\d+/)).not.toBeInTheDocument();
    });

    it('renders custom center content instead of step indicator', () => {
      render(
        <Card>
          <Card.Footer
            stepIndicator={{ current: 1, total: 3 }}
            centerContent={<span>Custom</span>}
          />
        </Card>
      );
      expect(screen.getByText('Custom')).toBeInTheDocument();
      expect(screen.queryByText('1/3')).not.toBeInTheDocument();
    });
  });

  // ============================================
  // Integration
  // ============================================

  describe('Full wizard flow', () => {
    it('renders complete card with header, content, and footer', () => {
      render(
        <Card variant="modal">
          <Card.Header
            title="Step 1"
            onClose={() => {}}
            progress={{ current: 1, total: 3 }}
          />
          <Card.Content padding="md">
            <input placeholder="Username" />
          </Card.Content>
          <Card.Footer
            stepIndicator={{ current: 1, total: 3 }}
            nextButton={{ label: 'Next', onClick: () => {} }}
          />
        </Card>
      );

      expect(screen.getByText('Step 1')).toBeInTheDocument();
      expect(screen.getByPlaceholderText('Username')).toBeInTheDocument();
      expect(screen.getByText('Next')).toBeInTheDocument();
      expect(screen.getByText('1/3')).toBeInTheDocument();
      expect(screen.getByRole('progressbar')).toBeInTheDocument();
    });
  });
});
